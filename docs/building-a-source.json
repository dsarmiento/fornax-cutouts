e=0.5,          # arcseconds per pixel (used for coordinate math)\n    max_cutout_size=2000,    # requests larger than this are rejected with 422\n    filter=[\"g\", \"r\", \"i\"],  # valid values for the filter parameter\n    survey=[\"wide\"],         # valid values for the survey parameter\n)","position":{"start":{"line":99,"column":1},"end":{"line":107,"column":1}},"key":"SBhEobhuHH"},{"type":"paragraph","position":{"start":{"line":109,"column":1},"end":{"line":109,"column":1}},"children":[{"type":"inlineCode","value":"MissionMetadata","position":{"start":{"line":109,"column":1},"end":{"line":109,"column":1}},"key":"LKDyVes0JL"},{"type":"text","value":" allows extra fields beyond the standard ones. Use this for mission-specific metadata you want to expose via the ","position":{"start":{"line":109,"column":1},"end":{"line":109,"column":1}},"key":"HlG6PblTmc"},{"type":"inlineCode","value":"/missions","position":{"start":{"line":109,"column":1},"end":{"line":109,"column":1}},"key":"zZNHKmEEHe"},{"type":"text","value":" endpoint:","position":{"start":{"line":109,"column":1},"end":{"line":109,"column":1}},"key":"pJtFxU04Xf"}],"key":"jECe9JU4sI"},{"type":"code","lang":"python","value":"MissionMetadata(\n    name=\"my_mission\",\n    pixel_size=0.5,\n    max_cutout_size=2000,\n    filter=[\"g\", \"r\", \"i\"],\n    survey=[\"wide\"],\n    # Mission-specific extras\n    wavelength_range=\"400-900nm\",\n    coverage_area=\"full sky\",\n)","position":{"start":{"line":111,"column":1},"end":{"line":122,"column":1}},"key":"NXYBN1TwPg"},{"type":"thematicBreak","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"key":"PrONInhGhX"},{"type":"heading","depth":2,"position":{"start":{"line":126,"column":1},"end":{"line":126,"column":1}},"children":[{"type":"text","value":"Step 4: Implement File Lookup","position":{"start":{"line":126,"column":1},"end":{"line":126,"column":1}},"key":"KAm2jEJyGr"}],"identifier":"step-4-implement-file-lookup","label":"Step 4: Implement File Lookup","html_id":"step-4-implement-file-lookup","implicit":true,"key":"Y9hKxDwm9b"},{"type":"paragraph","position":{"start":{"line":128,"column":1},"end":{"line":128,"column":1}},"children":[{"type":"text","value":"The core of your source is the file lookup logic. The approach depends on how your survey’s metadata is stored.","position":{"start":{"line":128,"column":1},"end":{"line":128,"column":1}},"key":"YW5s34kXEa"}],"key":"Qv0YJSlBut"},{"type":"heading","depth":3,"position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"children":[{"type":"text","value":"Option A: DuckDB + Parquet (recommended for large catalogs)","position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"key":"Kr0Wc5vKtb"}],"identifier":"option-a-duckdb-parquet-recommended-for-large-catalogs","label":"Option A: DuckDB + Parquet (recommended for large catalogs)","html_id":"option-a-duckdb-parquet-recommended-for-large-catalogs","implicit":true,"key":"p9xahq3zlb"},{"type":"paragraph","position":{"start":{"line":132,"column":1},"end":{"line":132,"column":1}},"children":[{"type":"text","value":"This is the pattern used by the PS1 source. Parquet files are queried directly with DuckDB, which supports both local files and S3:","position":{"start":{"line":132,"column":1},"end":{"line":132,"column":1}},"key":"l78o4bDVPg"}],"key":"zFAMIM2ULB"},{"type":"code","lang":"python","value":"import duckdb\nfrom fornax_cutouts.sources import cutout_registry, AbstractMissionSource, MissionMetadata\nfrom fornax_cutouts.models.base import Positions, TargetPosition\nfrom fornax_cutouts.models.cutouts import FilenameLookupResponse, FilenameWithMetadata\n\n\n@cutout_registry.register_source(\"my_mission\")\nclass MyMissionSource(AbstractMissionSource):\n    metadata = MissionMetadata(\n        name=\"my_mission\",\n        pixel_size=0.5,\n        max_cutout_size=2000,\n        filter=[\"g\", \"r\", \"i\"],\n        survey=[\"wide\"],\n    )\n\n    _metadata_path = \"s3://my-bucket/metadata/files.parquet\"\n\n    def __init__(self):\n        self.conn = duckdb.connect()\n        # Configure S3 access if needed\n        self.conn.execute(\"INSTALL httpfs; LOAD httpfs;\")\n        self.conn.execute(\"SET s3_region='us-east-1';\")\n\n    def get_filenames(\n        self,\n        position: TargetPosition | Positions,\n        filter: str | list[str] = [\"g\", \"r\", \"i\"],\n        survey: str | list[str] = [\"wide\"],\n        *args,\n        include_metadata: bool = False,\n        **kwargs,\n    ) -> list[FilenameLookupResponse]:\n        filter = self._cast_list_parameter(filter)\n\n        # Convert positions to RA/Dec arrays\n        positions = list(position) if not isinstance(position, list) else position\n        ra_min = min(p[0] for p in positions) - 0.1\n        ra_max = max(p[0] for p in positions) + 0.1\n        dec_min = min(p[1] for p in positions) - 0.1\n        dec_max = max(p[1] for p in positions) + 0.1\n\n        filter_list = \", \".join(f\"'{f}'\" for f in filter)\n        query = f\"\"\"\n            SELECT path, ra, dec, filter\n            FROM read_parquet('{self._metadata_path}')\n            WHERE ra BETWEEN {ra_min} AND {ra_max}\n              AND dec BETWEEN {dec_min} AND {dec_max}\n              AND filter IN ({filter_list})\n        \"\"\"\n\n        results = []\n        for row in self.conn.execute(query).fetchall():\n            path, ra, dec, filt = row\n            results.append(\n                FilenameLookupResponse(\n                    mission=\"my_mission\",\n                    target=(ra, dec),\n                    filenames=[FilenameWithMetadata(\n                        filename=path,\n                        metadata={\"filter\": filt} if include_metadata else None,\n                    )],\n                )\n            )\n\n        return results","position":{"start":{"line":134,"column":1},"end":{"line":201,"column":1}},"key":"EDMxU4uCuz"},{"type":"heading","depth":3,"position":{"start":{"line":203,"column":1},"end":{"line":203,"column":1}},"children":[{"type":"text","value":"Option B: Simple path construction","position":{"start":{"line":203,"column":1},"end":{"line":203,"column":1}},"key":"r7TNiYgtQn"}],"identifier":"option-b-simple-path-construction","label":"Option B: Simple path construction","html_id":"option-b-simple-path-construction","implicit":true,"key":"Q0T3LUUqjb"},{"type":"paragraph","position":{"start":{"line":205,"column":1},"end":{"line":205,"column":1}},"children":[{"type":"text","value":"For surveys with predictable file naming conventions:","position":{"start":{"line":205,"column":1},"end":{"line":205,"column":1}},"key":"WxTMfguqHt"}],"key":"SRh7tUdpQY"},{"type":"code","lang":"python","value":"def get_filenames(\n    self,\n    position: TargetPosition | Positions,\n    filter: str | list[str] = [\"g\"],\n    *args,\n    include_metadata: bool = False,\n    **kwargs,\n) -> list[FilenameLookupResponse]:\n    filter = self._cast_list_parameter(filter)\n\n    positions = [position] if isinstance(position, TargetPosition) else list(position)\n    results = []\n\n    for ra, dec in positions:\n        for f in filter:\n            # Construct a deterministic path from coordinates\n            tile = self._sky_to_tile(ra, dec)\n            path = f\"s3://my-bucket/{f}/{tile}.fits\"\n\n            results.append(\n                FilenameLookupResponse(\n                    mission=\"my_mission\",\n                    target=(ra, dec),\n                    filenames=[FilenameWithMetadata(filename=path)],\n                )\n            )\n\n    return results","position":{"start":{"line":207,"column":1},"end":{"line":236,"column":1}},"key":"xddxj3MEYk"},{"type":"thematicBreak","position":{"start":{"line":238,"column":1},"end":{"line":238,"column":1}},"key":"OC3EfHNSxd"},{"type":"heading","depth":2,"position":{"start":{"line":240,"column":1},"end":{"line":240,"column":1}},"children":[{"type":"text","value":"Step 5: Custom Valida